<xsd:schema xmlns:xsd="http://www.w3.org/2001/XMLSchema"
  xmlns="urn:veloconnect:transaction-1.4"
  xmlns:vt10="urn:veloconnect:transaction-1.0"
  xmlns:udt="urn:oasis:names:specification:ubl:schema:xsd:UnspecializedDatatypes-1.0" targetNamespace="urn:veloconnect:transaction-1.4" elementFormDefault="qualified" attributeFormDefault="unqualified">

  <xsd:import namespace="urn:oasis:names:specification:ubl:schema:xsd:UnspecializedDatatypes-1.0" schemaLocation="ubl/common/UBL-UnspecializedDatatypes-1.0.xsd"/>
  <xsd:import namespace="urn:veloconnect:profile-1.1" schemaLocation="profile-1.1.xsd" />
  <xsd:import namespace="urn:veloconnect:transaction-1.0" schemaLocation="transaction-1.0.xsd" />

  <xsd:element name="GetStatusRequest" type="vt10:RequestType">
    <xsd:annotation>
      <xsd:documentation>Request to determine the status of complex transactions.
If a transactionId is specified in the request, the status of this
Transaction to be returned; otherwise a list of all still open
Transactions (see specification)</xsd:documentation>
    </xsd:annotation>
  </xsd:element>

  <xsd:element name="GetStatusResponse">
    <xsd:annotation>
      <xsd:documentation>Response to GetStatusRequest.
If a transactionId is specified in the request, the status of this
Transaction to be returned; otherwise a list of all still open
Transactions (see specification)</xsd:documentation>
    </xsd:annotation>
    <xsd:complexType>
      <xsd:complexContent>
        <xsd:extension base="vt10:ResponseType">
          <xsd:sequence>
            <xsd:element name="TransactionStatus" type="TransactionStatusType" minOccurs="0" maxOccurs="unbounded" />
          </xsd:sequence>
        </xsd:extension>
      </xsd:complexContent>
    </xsd:complexType>
  </xsd:element>


  <xsd:complexType name="TransactionStatusType">
    <xsd:annotation>
      <xsd:documentation>Information about the state of a transaction.</xsd:documentation>
    </xsd:annotation>
    <xsd:sequence>
      <xsd:element name="TransactionId" type="xsd:normalizedString" />
      <xsd:element name="StatusCode" type="vt10:StatusCodeType" />
      <xsd:element name="Transaction" type="TransactionType" minOccurs="0" maxOccurs="1"/>
    </xsd:sequence>
  </xsd:complexType>


  <xsd:simpleType name="TransactionType">
    <xsd:annotation>
      <xsd:documentation>List of transactions</xsd:documentation>
    </xsd:annotation>
    <xsd:restriction base="xsd:normalizedString">
      <xsd:enumeration value="Order">
        <xsd:annotation>
          <xsd:documentation>Order</xsd:documentation>
        </xsd:annotation>
      </xsd:enumeration>
      <xsd:enumeration value="OrderInOnlineShop">
        <xsd:annotation>
          <xsd:documentation>OrderInOnlineShop</xsd:documentation>
        </xsd:annotation>
      </xsd:enumeration>
      <xsd:enumeration value="TextSearch">
        <xsd:annotation>
          <xsd:documentation>Volltextsuche</xsd:documentation>
        </xsd:annotation>
      </xsd:enumeration>
      <xsd:enumeration value="B2BStock">
        <xsd:annotation>
          <xsd:documentation>B2BStock</xsd:documentation>
        </xsd:annotation>
      </xsd:enumeration>
      <xsd:enumeration value="B2CStock">
        <xsd:annotation>
          <xsd:documentation>B2CStock</xsd:documentation>
        </xsd:annotation>
      </xsd:enumeration>
    </xsd:restriction>
  </xsd:simpleType>

</xsd:schema>
